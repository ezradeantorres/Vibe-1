# Copy to .env and fill in. .env is gitignored.

# Personal access token from https://app.netlify.com/user/applications#personal-access-tokens
# Used by src/deploy.py to push generated site bundles.
NETLIFY_AUTH_TOKEN=

# Optional: Netlify team slug if deploying under a team account rather than personal.
# NETLIFY_TEAM_SLUG=

# Note on LLM work:
#   Phase 1 deliberately does NOT call the Anthropic API programmatically.
#   The audit's CTA-above-fold check, the scrape extraction pass, and the
#   site copy generation are all done manually inside a Claude Code session
#   that reads the artifacts produced by src/audit.py and src/scrape.py.
#   See CLAUDE.md for the operator-facing handoff points.
