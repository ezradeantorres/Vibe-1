<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="{{ copy.theme_ink_bg or '#1F2A1D' }}">
  <meta name="robots" content="noindex,nofollow">
  <title>{{ copy.seo_title }}</title>
  <meta name="description" content="{{ copy.seo_description }}">
  <meta property="og:title" content="{{ copy.seo_title }}">
  <meta property="og:description" content="{{ copy.seo_description }}">
  <meta property="og:type" content="website">

  <link rel="icon" href="data:image/svg+xml,{{ favicon_svg | urlencode }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter:wght@400;500;600;700&display=swap">
  <link rel="stylesheet" href="./styles.css">
  {% if copy.theme_ink_bg or copy.theme_sage or copy.theme_amber %}
  <style>
    :root {
      {% if copy.theme_ink_bg %}--ink-bg: {{ copy.theme_ink_bg }}; --ink: {{ copy.theme_ink_bg }};{% endif %}
      {% if copy.theme_sage %}--sage: {{ copy.theme_sage }};{% endif %}
      {% if copy.theme_amber %}--amber: {{ copy.theme_amber }};{% endif %}
    }
  </style>
  {% endif %}
</head>
<body>
<a class="skip-link" href="#main">Skip to content</a>

{# ------- Util bar ------- #}
<div class="util">
  <div class="wrap util__inner">
    <ul class="util__list">
      {% if scrape.phone %}
      <li>
        <a href="tel:{{ scrape.phone | tel_href }}">
          {{ icons.phone | safe }} {{ scrape.phone }}
        </a>
      </li>
      {% endif %}
      {% if scrape.email %}
      <li class="util__hide-sm">
        <a href="mailto:{{ scrape.email }}">{{ icons.mail | safe }} {{ scrape.email }}</a>
      </li>
      {% endif %}
      {% if scrape.hours %}
      <li class="util__hide-sm">
        <span style="display:inline-flex;align-items:center;gap:.4rem;">
          {{ icons.clock | safe }} {{ scrape.hours }}
        </span>
      </li>
      {% endif %}
    </ul>
  </div>
</div>

{# ------- Header ------- #}
<header class="site-header">
  <div class="wrap header__inner">
    <a href="#" class="brand" aria-label="{{ scrape.name }}, home">
      <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
        <circle cx="16" cy="16" r="5" fill="var(--ink-bg)"/>
        <g fill="var(--sage)">
          <ellipse cx="16" cy="6" rx="3" ry="5"/>
          <ellipse cx="16" cy="26" rx="3" ry="5"/>
          <ellipse cx="6" cy="16" rx="5" ry="3"/>
          <ellipse cx="26" cy="16" rx="5" ry="3"/>
          <ellipse cx="9" cy="9" rx="4" ry="3" transform="rotate(-45 9 9)"/>
          <ellipse cx="23" cy="9" rx="4" ry="3" transform="rotate(45 23 9)"/>
          <ellipse cx="9" cy="23" rx="4" ry="3" transform="rotate(45 9 23)"/>
          <ellipse cx="23" cy="23" rx="4" ry="3" transform="rotate(-45 23 23)"/>
        </g>
      </svg>
      <span class="brand__name">
        {{ brand_first }}{% if brand_second %} <b>{{ brand_second }}</b>{% endif %}
        <small>{{ location_label }}</small>
      </span>
    </a>

    <nav class="nav" aria-label="Primary">
      <a class="nav__link" href="#care">Our Care</a>
      {% if copy.differentiators %}<a class="nav__link" href="#way">Our Approach</a>{% endif %}
      <a class="nav__link" href="#amenities">Amenities</a>
      <a class="nav__link" href="#gallery">Gallery</a>
      <a class="nav__link" href="#faq">FAQ</a>
      <a class="nav__link" href="#visit">Visit</a>
    </nav>

    <div class="header__actions">
      {% if scrape.phone %}
      <a class="nav-phone" href="tel:{{ scrape.phone | tel_href }}" aria-label="Call {{ scrape.phone }}">
        {{ icons.phone | safe }}<span>{{ scrape.phone }}</span>
      </a>
      {% endif %}
      <a class="btn btn--primary" href="#tour">{{ copy.primary_cta_text }}</a>
    </div>
  </div>
</header>

<main id="main">

{# ------- Hero ------- #}
<section class="hero {% if not copy.hero_image_path %}hero--no-photo{% endif %}" aria-labelledby="hero-title">
  <div class="hero__media">
    {% if copy.hero_image_path %}
    <img src="{{ copy.hero_image_path | img_src }}" alt="" loading="eager" fetchpriority="high">
    {% endif %}
  </div>
  <div class="wrap hero__inner">
    <div class="hero__copy">
      <span class="eyebrow eyebrow--on-dark">{{ eyebrow_text }}</span>
      <h1 id="hero-title">{{ copy.hero_headline | safe }}</h1>
      <p class="hero__sub">{{ copy.hero_subhead }}</p>
      <div class="hero__ctas">
        <a class="btn btn--primary btn--lg" href="#tour">
          {{ copy.primary_cta_text }} {{ icons.arrow_right | safe }}
        </a>
        {% if scrape.phone %}
        <a class="btn btn--ghost-light btn--lg" href="tel:{{ scrape.phone | tel_href }}">
          {{ icons.phone | safe }} {{ scrape.phone }}
        </a>
        {% endif %}
      </div>
      {% if copy.hero_stats %}
      <dl class="hero__stats hero__stats--{{ copy.hero_stats|length }}">
        {% for stat in copy.hero_stats %}
        <div class="hero__stat">
          <dt>{{ stat.value }}{% if stat.suffix %}<small>{{ stat.suffix }}</small>{% endif %}</dt>
          <dd>{{ stat.label | safe }}</dd>
        </div>
        {% endfor %}
      </dl>
      {% endif %}
    </div>
  </div>
</section>

{# ------- Trust band ------- #}
{% if copy.trust_badges %}
<section class="trust" aria-label="Credentials">
  <div class="wrap">
    <ul class="trust__list">
      {% for t in copy.trust_badges %}
      <li class="trust__item">
        <span class="trust__icon" aria-hidden="true">{{ icons.check | safe }}</span>
        <div>
          <strong>{{ t.label }}</strong>{% if t.sublabel %}<br>{{ t.sublabel }}{% endif %}
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
{% endif %}

{# ------- Welcome / value prop ------- #}
{% if copy.welcome_paragraph or copy.welcome_quote or copy.about_paragraph %}
<section aria-labelledby="welcome-title">
  <div class="wrap welcome__grid">
    <div class="welcome__media">
      {% if welcome_image_path %}
        <img src="{{ welcome_image_path | img_src }}" alt="">
      {% else %}
        <div class="placeholder" aria-hidden="true">{{ scrape.name }}</div>
      {% endif %}
      {% if welcome_badge %}
      <dl class="welcome__badge">
        <dt>{{ welcome_badge.value }}</dt>
        <dd>{{ welcome_badge.label }}</dd>
      </dl>
      {% endif %}
    </div>
    <div class="welcome__head">
      <span class="eyebrow">About {{ scrape.name }}</span>
      <h2 id="welcome-title">{{ welcome_headline | safe }}</h2>
      {% if copy.welcome_quote %}
      <p class="lede">{{ copy.welcome_quote | safe }}</p>
      {% endif %}
      {% if copy.welcome_paragraph %}
      <p class="welcome__copy" style="margin-top:1.25rem;">{{ copy.welcome_paragraph | safe }}</p>
      {% endif %}
      {% if copy.about_paragraph %}
      <p class="welcome__copy">{{ copy.about_paragraph }}</p>
      {% endif %}
      <a class="btn btn--ghost welcome__cta" href="#care">See how we care {{ icons.arrow_right | safe }}</a>
    </div>
  </div>
</section>
{% endif %}

{# ------- Levels of care ------- #}
{% if copy.services %}
<section class="care" id="care" aria-labelledby="care-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Levels of care</span>
      <h2 id="care-title">{{ care_headline | safe }}</h2>
      <p>{{ care_intro }}</p>
    </div>
    <div class="care__grid">
      {% for s in copy.services %}
      <article class="care-card">
        <div class="care-card__media">
          {% if care_card_images.get(s.key) %}
            <img src="{{ care_card_images[s.key] }}" alt="" loading="lazy">
          {% else %}
            <div class="placeholder" aria-hidden="true">{{ s.headline }}</div>
          {% endif %}
        </div>
        <div class="care-card__body">
          <span class="care-card__tag">{{ care_card_tags.get(s.key, "Care") }}</span>
          <h3>{{ s.headline }}</h3>
          <p>{{ s.body }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ------- Way / differentiators ------- #}
{% if copy.differentiators %}
<section class="way" id="way" aria-labelledby="way-title">
  <div class="wrap way__inner">
    <div class="section-head">
      <span class="eyebrow eyebrow--on-dark">Our approach</span>
      <h2 id="way-title">{{ way_headline | safe }}</h2>
      <p>{{ way_intro }}</p>
    </div>
    <div class="way__grid">
      {% for d in copy.differentiators %}
      <div class="way-pillar">
        <div class="way-pillar__num">{{ d.number }}</div>
        <h3>{{ d.headline }}</h3>
        <p>{{ d.body }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ------- Amenities ------- #}
{% if copy.rich_amenities or scrape.amenities %}
<section class="amenities" id="amenities" aria-labelledby="amenities-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Daily life</span>
      <h2 id="amenities-title">{{ amenities_headline | safe }}</h2>
      <p>{{ amenities_intro }}</p>
    </div>
    <div class="amenities__grid">
      {% if copy.rich_amenities %}
        {% for a in copy.rich_amenities %}
        <div class="amenity">
          <div class="amenity__icon" aria-hidden="true">{{ icons.dot | safe }}</div>
          <h4>{{ a.name }}</h4>
          {% if a.description %}<p>{{ a.description }}</p>{% endif %}
        </div>
        {% endfor %}
      {% else %}
        {% for a in scrape.amenities %}
        <div class="amenity">
          <div class="amenity__icon" aria-hidden="true">{{ icons.dot | safe }}</div>
          <h4>{{ a }}</h4>
        </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
{% endif %}

{# ------- Gallery ------- #}
<section class="gallery" id="gallery" aria-labelledby="gallery-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Inside our community</span>
      <h2 id="gallery-title">{{ gallery_headline | safe }}</h2>
      <p>{{ gallery_intro }}</p>
    </div>
    <div class="gallery__grid">
      {% set tile_classes = ["", "gallery__item--tall", "", "gallery__item--wide", "", "gallery__item--tall"] %}
      {% set placeholder_caps = placeholder_gallery_captions %}
      {% if copy.photo_gallery_paths %}
        {% for p in copy.photo_gallery_paths %}
        <div class="gallery__item {{ tile_classes[loop.index0 % tile_classes|length] }}">
          <img src="{{ p | img_src }}" alt="{{ scrape.name }}" loading="lazy">
        </div>
        {% endfor %}
      {% else %}
        {% for cap in placeholder_caps %}
        <div class="gallery__item {{ tile_classes[loop.index0 % tile_classes|length] }}" aria-hidden="true">
          <div class="placeholder">{{ cap }}</div>
        </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{# ------- Pricing ------- #}
{% if copy.pricing %}
<section class="pricing" aria-labelledby="pricing-title">
  <div class="wrap">
    <div class="pricing__card">
      <div>
        <span class="eyebrow eyebrow--on-dark">Pricing</span>
        <h2 id="pricing-title">{{ pricing_headline | safe }}</h2>
        <p class="lede">{{ copy.pricing.intro or pricing_default_intro }}</p>
        {% if copy.pricing.includes %}
        <ul class="pricing__list">
          {% for inc in copy.pricing.includes %}
          <li>{{ icons.check | safe }} {{ inc }}</li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      <div class="pricing__numbers">
        <div class="pricing__range">
          ${{ "{:,}".format(copy.pricing.from_dollars) }}<span class="per">/mo</span>
        </div>
        {% if copy.pricing.avg_dollars %}
        <div class="pricing__avg">Avg. all-in: ${{ "{:,}".format(copy.pricing.avg_dollars) }}/mo</div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{% endif %}

{# ------- FAQ ------- #}
{% if copy.faqs %}
<section class="faq" id="faq" aria-labelledby="faq-title">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Common questions</span>
      <h2 id="faq-title">Questions families ask.</h2>
    </div>
    <div class="faq__list">
      {% for f in copy.faqs %}
      <details class="faq-item">
        <summary>{{ f.question }}</summary>
        <div class="faq__body"><p>{{ f.answer }}</p></div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ------- Visit + Lead form ------- #}
<section class="visit" id="visit" aria-labelledby="visit-title">
  <div class="wrap visit__grid">
    <div class="visit__info">
      <span class="eyebrow">Schedule a visit</span>
      <h2 id="visit-title">{{ visit_headline | safe }}</h2>
      <p class="lede">{{ visit_intro }}</p>
      <div class="visit__rows">
        {% if scrape.address %}
        <div class="visit-row">
          <div class="visit-row__icon" aria-hidden="true">{{ icons.pin | safe }}</div>
          <div>
            <div class="visit-row__label">Address</div>
            <div class="visit-row__value">{{ scrape.address }}</div>
          </div>
        </div>
        {% endif %}
        {% if scrape.phone %}
        <div class="visit-row">
          <div class="visit-row__icon" aria-hidden="true">{{ icons.phone | safe }}</div>
          <div>
            <div class="visit-row__label">Phone</div>
            <div class="visit-row__value"><a href="tel:{{ scrape.phone | tel_href }}">{{ scrape.phone }}</a></div>
          </div>
        </div>
        {% endif %}
        {% if scrape.email %}
        <div class="visit-row">
          <div class="visit-row__icon" aria-hidden="true">{{ icons.mail | safe }}</div>
          <div>
            <div class="visit-row__label">Email</div>
            <div class="visit-row__value"><a href="mailto:{{ scrape.email }}">{{ scrape.email }}</a></div>
          </div>
        </div>
        {% endif %}
        {% if scrape.hours %}
        <div class="visit-row">
          <div class="visit-row__icon" aria-hidden="true">{{ icons.clock | safe }}</div>
          <div>
            <div class="visit-row__label">Hours</div>
            <div class="visit-row__value">{{ scrape.hours }}</div>
          </div>
        </div>
        {% endif %}
      </div>
    </div>

    <div id="tour">
      <form class="lead__form" name="lead" method="POST" action="?success=1" data-netlify="true" netlify-honeypot="bot-field">
        <p class="success-banner" id="success-banner">Thanks — we'll be in touch shortly.</p>
        <input type="hidden" name="form-name" value="lead">
        <input type="hidden" name="community" value="{{ scrape.slug }}">
        <p class="honeypot"><label>Don't fill this out: <input name="bot-field"></label></p>

        <div class="row two">
          <div class="field">
            <label for="first">First name</label>
            <input id="first" name="first_name" required>
          </div>
          <div class="field">
            <label for="last">Last name</label>
            <input id="last" name="last_name" required>
          </div>
        </div>
        <div class="row two">
          <div class="field">
            <label for="email">Email</label>
            <input id="email" type="email" name="email" required>
          </div>
          <div class="field">
            <label for="phone">Phone</label>
            <input id="phone" type="tel" name="phone">
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label for="relationship">Who are you researching for?</label>
            <select id="relationship" name="relationship">
              <option>A parent</option>
              <option>A spouse</option>
              <option>Myself</option>
              <option>Another family member</option>
              <option>Other</option>
            </select>
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label for="message">What's most important to you?</label>
            <textarea id="message" name="message" placeholder="Mobility needs, dementia diagnosis, timing pressures…"></textarea>
          </div>
        </div>
        <div class="actions">
          <button class="btn btn--primary btn--lg" type="submit">Request a tour</button>
        </div>
        <p class="privacy">We'll only use your information to follow up about a visit. No marketing email lists.</p>
      </form>
    </div>
  </div>
</section>

{# ------- CTA strip ------- #}
<section class="cta-strip">
  <div class="wrap">
    <h2>{{ copy.cta_strip_headline or default_cta_headline | safe }}</h2>
    <p>Most families decide whether a place feels right within the first ten minutes of walking in. Come see for yourself — even if it's not us, we want to help you find the right home.</p>
    <div class="cta-strip__buttons">
      <a class="btn btn--primary btn--lg" href="#tour">{{ copy.primary_cta_text }}</a>
      {% if scrape.phone %}
      <a class="btn btn--ghost-light btn--lg" href="tel:{{ scrape.phone | tel_href }}">
        {{ icons.phone | safe }} Call {{ scrape.phone }}
      </a>
      {% endif %}
    </div>
  </div>
</section>

</main>

{# ------- Footer ------- #}
<footer class="site-footer">
  <div class="wrap">
    <div class="footer__grid">
      <div class="footer__brand">
        <a href="#" class="brand">
          <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
            <circle cx="16" cy="16" r="5" fill="var(--sage)"/>
            <g fill="var(--sage-tint-2)">
              <ellipse cx="16" cy="6" rx="3" ry="5"/>
              <ellipse cx="16" cy="26" rx="3" ry="5"/>
              <ellipse cx="6" cy="16" rx="5" ry="3"/>
              <ellipse cx="26" cy="16" rx="5" ry="3"/>
              <ellipse cx="9" cy="9" rx="4" ry="3" transform="rotate(-45 9 9)"/>
              <ellipse cx="23" cy="9" rx="4" ry="3" transform="rotate(45 23 9)"/>
              <ellipse cx="9" cy="23" rx="4" ry="3" transform="rotate(45 9 23)"/>
              <ellipse cx="23" cy="23" rx="4" ry="3" transform="rotate(-45 23 23)"/>
            </g>
          </svg>
          <span class="brand__name">
            {{ brand_first }}{% if brand_second %} <b>{{ brand_second }}</b>{% endif %}
            <small>{{ location_label }}</small>
          </span>
        </a>
        <p>{{ footer_blurb }}</p>
      </div>
      <div class="footer__col">
        <h4>Visit</h4>
        <address>
          {% if scrape.address %}<strong>{{ scrape.name }}</strong>{{ scrape.address }}{% endif %}
          {% if scrape.phone %}<br><br>{{ scrape.phone }}{% endif %}
          {% if scrape.email %}<br>{{ scrape.email }}{% endif %}
          {% if scrape.hours %}<br>{{ scrape.hours }}{% endif %}
        </address>
      </div>
      <div class="footer__col">
        <h4>Explore</h4>
        <ul>
          <li><a href="#care">Our Care</a></li>
          {% if copy.differentiators %}<li><a href="#way">Our Approach</a></li>{% endif %}
          <li><a href="#amenities">Amenities</a></li>
          <li><a href="#gallery">Gallery</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#visit">Schedule a Visit</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h4>Compliance</h4>
        <ul>
          <li>Equal Opportunity Housing</li>
          <li>ADA Friendly</li>
          <li>Licensed: <em>on file</em></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <span>&copy; {{ year }} {{ scrape.name }}. All rights reserved.</span>
      <span class="footer__demo">Demo built for {{ scrape.name }} by Ezra · {{ year }}</span>
    </div>
  </div>
</footer>

<script>
  if (new URLSearchParams(location.search).get('success') === '1') {
    var b = document.getElementById('success-banner');
    if (b) b.classList.add('is-visible');
    var f = document.querySelector('.lead__form');
    if (f) f.scrollIntoView({behavior:'smooth', block:'start'});
  }
</script>

</body>
</html>
